    <h1 class="article-title">{{ title | safe }}</h1>
    <div class="article-meta">
      <span class="article-author">{{ author }}</span>
      {% if role %}<span class="article-role">{{ role }}</span>{% endif %}
      <span class="article-date">{{ date | readableDate }}</span>
    </div>
  </div>

  {% if heroImage %}<div class="article-hero-image">
    <img src="{{ heroImage }}" alt="{{ heroAlt | default(title) }}" style="width:100%;display:block;" />
    {% if heroCaption %}<p class="img-caption">{{ heroCaption | safe }}</p>{% endif %}
  </div>{% endif %}

  <div class="article-body">
    {% if intro %}<p class="intro">{{ intro | safe }}</p>{% endif %}
    {{ bodyBlocks | renderBody | safe }}
    {% if outro %}<p class="article-outro">{{ outro | safe }}</p>{% endif %}
    <p style="margin-top: 36px; padding-top: 24px; border-top: 1px solid var(--divider); font-style: italic; color: var(--sand); font-size: 15px;">Stay in the niche. There's more where this came from on our newsletter...<a href="https://feminiche-newsletter.beehiiv.com" target="_blank" style="color: #FF2D8A; font-weight: 700; text-decoration: none;">subscribe now</a>.</p>
  </div>

  {% if authorBio %}<div class="author-bio">
    <span class="author-bio-label">About the Author</span>
    <p class="author-bio-text">{{ authorBio | safe }}</p>
  </div>{% endif %}

  <div style="text-align:center; padding: 48px 0;">
