      <a href="contact.html">Contact</a>
      <a href="index.html#newsletter" style="color:#FF2D8A;font-weight:700;border-top:2px solid var(--ink);">Subscribe to Newsletter</a>
    </div>
  </footer>
  <div class="footer-bottom">
    <p>&copy; 2026 FemiNICHE &nbsp;&middot;&nbsp; All rights reserved</p>
  </div>

</body>
