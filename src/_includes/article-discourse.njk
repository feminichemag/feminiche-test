<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="icon" type="image/x-icon" href="favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="favicon-32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="favicon-16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="apple-touch-icon.png">
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title | safe }} &mdash; FemiNICHE</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --cream: #F5EBE0;
      --parchment: #E8D8C8;
      --green: #6B7A2A;
      --green-dark: #6B2045;
      --green-light: #D4A0A8;
      --sand: #8A6858;
      --ink: #4A1528;
      --dark: #3D0F28;
      --muted: #8A6858;
      --divider: #D4A0A8;
      --neon: #8B3558;
      --neon-dim: #6B2045;
    }

    html { scroll-behavior: smooth; scroll-padding-top: 120px; }
    body { background-color: var(--cream); color: var(--ink); font-family: 'Hoefler Text', 'Georgia', serif; font-size: 17px; line-height: 1.7; -webkit-font-smoothing: antialiased; }
    a { color: inherit; text-decoration: none; }

    .announcement { background: var(--ink); color: var(--cream); padding: 9px 0; font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; overflow: hidden; white-space: nowrap; }
    .announcement-track { display: inline-flex; animation: ticker 32s linear infinite; }
    .announcement-track:hover { animation-play-state: paused; }
    .announcement-item { display: inline-flex; align-items: center; gap: 16px; padding: 0 36px; }
    .announcement-item span { color: #FF2D8A; font-style: italic; letter-spacing: 0.04em; text-transform: none; font-size: 13px; }
    .announcement-dot { color: var(--green-light); opacity: 0.6; }
    @keyframes ticker { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

    header { background: var(--cream); border-bottom: 2px solid var(--ink); padding: 0 48px; position: sticky; top: 0; z-index: 100; }
    .header-top { display: flex; align-items: center; justify-content: space-between; padding: 16px 0 12px; border-bottom: 1px solid var(--divider); }
    .logo { font-size: 36px; font-weight: 700; color: var(--ink); letter-spacing: -0.03em; line-height: 1; }
    .logo span { color: var(--neon); }
    .header-tagline { font-style: italic; font-size: 14px; color: var(--muted); }
    .header-actions { display: flex; align-items: center; gap: 18px; }
    .btn-submit { background: var(--neon); color: #fff; padding: 10px 24px; font-size: 12px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; border: none; cursor: pointer; transition: background 0.18s; display: inline-block; }
    .btn-submit:hover { background: var(--neon-dim); }
    .btn-subscribe { background: transparent; color: #FF2D8A; padding: 10px 24px; font-size: 12px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; border: 2px solid #FF2D8A; cursor: pointer; transition: background 0.18s, color 0.18s; display: inline-block; }
    .btn-subscribe:hover { background: #FF2D8A; color: var(--ink); }
    .social-icons { display: flex; gap: 14px; align-items: center; }
    .social-icons a { color: var(--muted); font-size: 15px; transition: color 0.18s; }
    .social-icons a:hover { color: var(--neon); }
    nav { display: flex; padding: 10px 0 9px; align-items: center; }
    nav a { font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); padding: 3px 20px 3px 0; margin-right: 20px; border-right: 1px solid var(--divider); transition: color 0.18s; white-space: nowrap; }
    nav a:last-child { border-right: none; margin-right: 0; }
    nav a:first-child { padding-left: 0; }
    nav a:hover { color: var(--neon); }
    .nav-category-label { font-size: 10px; letter-spacing: 0.2em; color: var(--green); text-transform: uppercase; padding-right: 14px; margin-right: 14px; border-right: 1px solid var(--divider); font-style: italic; }

    .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 4px; background: none; border: none; }
    .hamburger span { display: block; width: 22px; height: 2px; background: var(--ink); transition: all 0.25s; }
    .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .hamburger.open span:nth-child(2) { opacity: 0; }
    .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
    .mobile-nav { display: none; flex-direction: column; background: var(--cream); border-top: 1px solid var(--divider); padding: 4px 0 12px; }
    .mobile-nav.open { display: flex; }
    .mobile-nav a { font-size: 14px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); padding: 13px 24px; border-bottom: 1px solid var(--divider); transition: color 0.18s; }
    .mobile-nav a:last-child { border-bottom: none; }
    .mobile-nav a:hover { color: var(--neon); }

    .article-header { max-width: 720px; margin: 64px auto 0; padding: 0 48px 40px; border-bottom: 1px solid var(--divider); }
    .article-breadcrumb { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--neon); font-weight: 700; margin-bottom: 16px; display: flex; align-items: center; gap: 10px; }
    .article-breadcrumb a { color: var(--muted); transition: color 0.18s; }
    .article-breadcrumb a:hover { color: var(--neon); }
    .article-breadcrumb-sep { color: var(--divider); }
    .article-title { font-size: 52px; font-weight: 700; line-height: 1.07; letter-spacing: -0.02em; color: var(--ink); }
    .article-meta { display: flex; align-items: center; gap: 20px; margin-top: 24px; padding-top: 20px; border-top: 1px solid var(--divider); flex-wrap: wrap; }
    .article-author { font-size: 14px; font-weight: 700; color: var(--ink); }
    .article-role { font-size: 13px; font-style: italic; color: var(--sand); }
    .article-date { font-size: 13px; color: var(--sand); font-style: italic; margin-left: auto; }

    .article-hero-image { max-width: 720px; margin: 0 auto; padding: 40px 48px 0; }
    .article-hero-image img { width: 100%; display: block; }
    .img-caption { font-size: 12px; font-style: italic; color: var(--sand); margin-top: 10px; }

    .article-body { max-width: 720px; margin: 0 auto; padding: 44px 48px 0; }
    .article-body .intro { font-size: 19px; line-height: 1.8; color: var(--ink); margin-bottom: 36px; }
    .article-body p { margin-bottom: 24px; }
    .article-body p:last-child { margin-bottom: 0; }
    .qa-block { margin-bottom: 36px; }
    .qa-question { font-size: 18px; font-weight: 700; color: var(--ink); line-height: 1.4; margin-bottom: 12px; }
    .qa-answer { font-size: 18px; line-height: 1.8; color: var(--muted); }
    .qa-answer .speaker { font-weight: 700; color: var(--ink); font-style: normal; }
    .qa-divider { width: 40px; height: 2px; background: var(--neon); margin: 36px 0; }
    .article-outro { font-size: 16px; font-style: italic; color: var(--sand); margin-top: 36px; padding-top: 24px; border-top: 1px solid var(--divider); line-height: 1.7; }

    .author-bio { max-width: 720px; margin: 52px auto 0; padding: 28px 48px; border-top: 2px solid var(--ink); border-bottom: 1px solid var(--divider); display: flex; gap: 20px; align-items: flex-start; }
    .author-bio-label { font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--neon); font-weight: 700; white-space: nowrap; padding-top: 3px; }
    .author-bio-text { font-size: 15px; font-style: italic; color: var(--muted); line-height: 1.65; }

    .comments-section { max-width: 720px; margin: 52px auto 0; padding: 0 48px 52px; }
    .comments-header { display: flex; align-items: center; gap: 16px; margin-bottom: 32px; }
    .comments-header h2 { font-size: 10px; letter-spacing: 0.24em; text-transform: uppercase; color: var(--ink); font-weight: 700; white-space: nowrap; }
    .comments-line { flex: 1; height: 1px; background: var(--divider); }
    .comment-form { margin-bottom: 48px; }
    .comment-form-fields { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px; }
    .comment-form input, .comment-form textarea { width: 100%; padding: 12px 16px; font-family: 'Hoefler Text', 'Georgia', serif; font-size: 15px; background: var(--parchment); border: 1px solid var(--divider); color: var(--ink); outline: none; transition: border-color 0.18s; }
    .comment-form input:focus, .comment-form textarea:focus { border-color: var(--neon); }
    .comment-form input::placeholder, .comment-form textarea::placeholder { color: var(--sand); }
    .comment-form textarea { resize: vertical; min-height: 120px; margin-bottom: 12px; }
    .comment-form button { background: var(--ink); color: var(--cream); padding: 12px 28px; font-family: 'Hoefler Text', 'Georgia', serif; font-size: 12px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; border: none; cursor: pointer; transition: background 0.18s; }
    .comment-form button:hover { background: var(--neon); }
    .comment { padding: 24px 0; border-bottom: 1px solid var(--divider); }
    .comment:last-child { border-bottom: none; }
    .comment-meta { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; }
    .comment-avatar { width: 36px; height: 36px; border-radius: 50%; background: var(--green); display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: 700; color: var(--cream); flex-shrink: 0; }
    .comment-name { font-size: 14px; font-weight: 700; color: var(--ink); }
    .comment-date { font-size: 12px; font-style: italic; color: var(--sand); margin-left: auto; }
    .comment-text { font-size: 16px; color: var(--muted); line-height: 1.7; padding-left: 48px; }

    .read-more { max-width: 720px; margin: 0 auto; padding: 0 48px 80px; border-top: 1px solid var(--divider); padding-top: 48px; }
    .read-more-header { display: flex; align-items: center; gap: 16px; margin-bottom: 28px; }
    .read-more-header h2 { font-size: 10px; letter-spacing: 0.24em; text-transform: uppercase; color: var(--ink); font-weight: 700; white-space: nowrap; }
    .read-more-line { flex: 1; height: 1px; background: var(--divider); }
    .read-more-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 28px; }
    .read-more-card { cursor: pointer; }
    .read-more-img { width: 100%; aspect-ratio: 3/2; }
    .img-a { background: linear-gradient(160deg, #6B2045, #E8D8C8); }
    .img-b { background: linear-gradient(160deg, #3D2E50, #6B7A3A); }
    .read-more-cat { font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--neon); font-weight: 700; margin-top: 12px; display: block; }
    .read-more-title { font-size: 17px; font-weight: 700; line-height: 1.3; color: var(--ink); margin-top: 5px; transition: color 0.18s; }
    .read-more-card:hover .read-more-title { color: var(--green); }
    .read-more-meta { font-size: 11px; color: var(--sand); margin-top: 7px; font-style: italic; }

    footer { background: #2D0A18; color: var(--sand); padding: 52px 48px; display: grid; grid-template-columns: 1.4fr 1fr 1fr; gap: 48px; }
    .footer-logo { font-size: 28px; font-weight: 700; color: var(--cream); letter-spacing: -0.02em; }
    .footer-logo span { color: var(--neon); }
    .footer-tagline { font-style: italic; font-size: 14px; color: var(--green-light); margin-top: 10px; }
    .footer-col h4 { font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--neon); margin-bottom: 16px; font-weight: 700; }
    .footer-col a { display: block; font-size: 14px; color: #C8A0B0; margin-bottom: 10px; transition: color 0.18s; }
    .footer-col a:hover { color: var(--cream); }
    .footer-bottom { background: #2D0A18; border-top: 1px solid #3D0F28; padding: 16px 48px; text-align: center; }
    .footer-bottom p { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; }

    @media (max-width: 768px) {
      header { padding: 0 18px; }
      .header-top { padding: 13px 0 11px; }
      .header-tagline { display: none; }
      .logo { font-size: 28px; }
      .social-icons { display: none; }
      .btn-subscribe { display: none; }
      .hamburger { display: flex; }
      nav { display: none; }
      .article-header { margin-top: 36px; padding: 0 18px 28px; }
      .article-title { font-size: 32px; }
      .article-meta { gap: 10px; }
      .article-date { margin-left: 0; }
      .article-hero-image { padding: 28px 18px 0; }
      .article-body { padding: 32px 18px 0; }
      .article-body .intro { font-size: 17px; }
      .qa-question { font-size: 16px; }
      .qa-answer { font-size: 16px; }
      .author-bio { padding: 24px 18px; flex-direction: column; gap: 10px; }
      .comments-section { padding: 0 18px 40px; }
      .comment-form-fields { grid-template-columns: 1fr; }
      .comment-text { padding-left: 0; margin-top: 8px; }
      .read-more { padding: 36px 18px 60px; }
      .read-more-grid { grid-template-columns: 1fr; gap: 24px; }
      footer { grid-template-columns: 1fr; padding: 36px 18px; gap: 28px; }
      .footer-bottom { padding: 14px 18px; }
    }
  </style>
</head>
<body>

